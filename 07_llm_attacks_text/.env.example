# Model to use (default: llama3.2:3b — ~2.0 GB, fast inference, good capabilities)
# Alternatives:
#   qwen2.5:7b           (~4.7 GB, stronger reasoning, slower)
#   mistral:7b-instruct  (~4.1 GB, well-known, easy to jailbreak for demos)
#   gemma2:2b            (~1.6 GB, lightest option)
MODEL_NAME=llama3.2:3b
